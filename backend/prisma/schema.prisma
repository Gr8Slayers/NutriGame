// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb" // CockroachDB kullanıyoruz
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(sequence())
  username  String    @unique
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  profile   UserProfile?  // sadece Prisma için, DB kolonu değil
  streak    Streak?   // Her kullanıcının bir streak kaydı olacak
  mealPhotos MealPhoto[]
}

model UserProfile {
  id             Int      @id @default(sequence())
  userId         Int      @unique
  age            Int
  gender         String
  weight         Int
  height         Int
  target_weight  Int
  reason_to_diet String
  avatar_url     String

  // her UserProfile in bir User a bagli olmasini sagliyor, user da bir row silindiginde burada ilgili user in profili siliniyor
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FoodLookup{
  id              Int      @id @default(sequence())
  food_id         Int      @unique
  food_name       String
  p_unit          String //porsiyon miktarinin hangi birim oldugu orn. gram, ml, tabak, kasik
  p_amount        Float //porsiyon miktari orn. 100(gram), 200(ml), 2(tabak), 3(kasik)
  p_calorie       Float
  p_protein       Float //birimi zaten hep gram bu yuzden ozellestirmiyorum direkt miktar tutuluyor
  p_fat           Float //birimi zaten hep gram bu yuzden ozellestirmiyorum direkt miktar tutuluyor
  p_carb          Float //birimi zaten hep gram bu yuzden ozellestirmiyorum direkt miktar tutuluyor
}

model MealLog {
  meal_log_id     Int      @id @default(sequence())
  userId          Int      
  date            DateTime @db.Date @default(now()) // prisma sadece Date kabul etmiyor Datetime var sadece, yanina ekledigim aciklama db de Date olarak tutlmayi sagliyor
  meal_category   String //ogun tipi orn. {breakfast, lunch, dinner, snack} bunlardan baska olmayacak enum lanabilir
  p_count         Int //kac porsiyon eklendigi, toplamlar buna gore hesaplanacak
  food_id         Int
  food_name       String
  p_unit          String //porsiyon miktarinin hangi birim oldugu orn. gram, ml, tabak, kasik
  t_amount        Float // portion_count ile portion amount carpimi, yani o log icin total amount
  t_calorie       Float
  t_protein       Float
  t_fat           Float
  t_carb          Float
}

model MealTotals{
  id              Int      @id @default(sequence())
  userId          Int
  date            DateTime @db.Date @default(now()) // prisma sadece Date kabul etmiyor Datetime var sadece, yanina ekledigim aciklama db de Date olarak tutlmayi sagliyor
  meal_category   String //ogun tipi orn. {breakfast, lunch, dinner, snack, OVERALL(yani tum gun)} bunlardan baska olmayacak enum lanabilir     
  t_calorie       Float
  t_protein       Float
  t_fat           Float
  t_carb          Float

  @@unique([userId, date, meal_category]) //1 user 1 gunde 1 ogun tipi icin birden fazla row olusturamaz
}

model WaterLog {
  water_log_id    Int      @id @default(sequence())
  userId          Int      
  date            DateTime @db.Date @default(now()) // prisma sadece Date kabul etmiyor Datetime var sadece, yanina ekledigim aciklama db de Date olarak tutlmayi sagliyor
  t_amount        Int //yeni eklenen su miktarini o anki totale ekleyip yeni totali kaydediyorum

  @@unique([userId, date]) //1 user 1 gun icin birden fazla row olusturamaz
}
model MealPhoto {
  photoId      Int      @id @default(sequence())
  userId       Int
  date         DateTime @db.Date @default(now()) 
  mealCategory String  
  imageUrl     String   // Yüklenen resmin Render, S3 veya local sunucudaki adresi
  uploadedAt   DateTime @default(now())

  // User tablosu ile olan 1-to-Many "uploads" ilişkisinin bağlantısı
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserFollow {
  id          Int      @id @default(sequence())
  followerId  Int
  followingId Int

  @@unique([followerId, followingId])
}

model Post {
  id                  Int           @id @default(sequence())
  userId              Int
  caption             String        @default("")
  imageUrl            String?
  isRecipe            Boolean       @default(false)
  recipeTitle         String?
  recipeIngredients   String?
  recipeInstructions  String?
  recipeCalories      Float?
  recipePrepTime      Int?
  createdAt           DateTime      @default(now())

  likes               PostLike[]
  comments            PostComment[]
}

model PostLike {
  id      Int  @id @default(sequence())
  postId  Int
  userId  Int
  post    Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id        Int      @id @default(sequence())
  postId    Int
  userId    Int
  text      String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Streak {
  id             Int      @id @default(sequence())
  userId         Int      @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActiveDate DateTime @default(now())
  totalPoints    Int      @default(0)
}

model Challenge {
  id           Int      @id @default(sequence())
  title        String
  type         String   // calorie, water, sugar, step
  startDate    DateTime @default(now())
  endDate      DateTime
  status       String   // pending, active, completed, cancelled
  creatorId    Int
  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id             Int       @id @default(sequence())
  challengeId    Int
  userId         Int
  role           String    // creator, invitee
  status         String    // pending, accepted, declined
  rewardClaimed  Boolean   @default(false)
  joinedAt       DateTime  @default(now())
  challenge      Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

