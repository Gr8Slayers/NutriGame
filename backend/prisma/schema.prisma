generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL")
}

model User {
  id              Int             @id @default(sequence(maxValue: 2147483647))
  username        String          @unique
  email           String          @unique
  password        String
  createdAt       DateTime        @default(now())
  expoPushToken   String?
  chatSessions    ChatSession[]
  dailyProgresses DailyProgress[]
  mealPhotos      MealPhoto[]
  notifications   Notification[]
  streak          Streak?
  profile         UserProfile?
}

model Notification {
  id        Int      @id @default(sequence(maxValue: 2147483647))
  userId    Int
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id             Int    @id @default(sequence(maxValue: 2147483647))
  userId         Int    @unique
  age            Int
  gender         String
  weight         Int
  height         Int
  target_weight  Int
  reason_to_diet String
  avatar_url     String
  user           User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FoodLookup {
  id        Int    @id @default(sequence())
  food_id   Int    @unique
  food_name String
  p_unit    String
  p_amount  Float
  p_calorie Float
  p_protein Float
  p_fat     Float
  p_carb    Float
}

model FoodSearchCache {
  id        Int      @id @default(sequence())
  query     String   @unique
  results   String
  createdAt DateTime @default(now())
}

model MealLog {
  meal_log_id   Int      @id @default(sequence())
  userId        Int
  date          DateTime @default(now()) @db.Date
  meal_category String
  p_count       Int
  food_id       Int
  food_name     String
  p_unit        String
  t_amount      Float
  t_calorie     Float
  t_protein     Float
  t_fat         Float
  t_carb        Float
}

model MealTotals {
  id            Int      @id @default(sequence())
  userId        Int
  date          DateTime @default(now()) @db.Date
  meal_category String
  t_calorie     Float
  t_protein     Float
  t_fat         Float
  t_carb        Float

  @@unique([userId, date, meal_category])
}

model WaterLog {
  water_log_id Int      @id @default(sequence(maxValue: 2147483647))
  userId       Int
  date         DateTime @default(now()) @db.Date
  amount       Int
  portion_name String
}

model MealPhoto {
  photoId      Int      @id @default(sequence(maxValue: 2147483647))
  userId       Int
  date         DateTime @default(now()) @db.Date
  mealCategory String
  imageUrl     String
  uploadedAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserFollow {
  id          Int @id @default(sequence(maxValue: 2147483647))
  followerId  Int
  followingId Int

  @@unique([followerId, followingId])
}

model Post {
  id                 Int           @id @default(sequence(maxValue: 2147483647))
  userId             Int
  caption            String        @default("")
  imageUrl           String?
  isRecipe           Boolean       @default(false)
  recipeTitle        String?
  recipeIngredients  String?
  recipeInstructions String?
  recipeCalories     Float?
  recipePrepTime     Int?
  createdAt          DateTime      @default(now())
  comments           PostComment[]
  likes              PostLike[]
}

model PostLike {
  id     Int  @id @default(sequence(maxValue: 2147483647))
  postId Int
  userId Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id        Int      @id @default(sequence(maxValue: 2147483647))
  postId    Int
  userId    Int
  text      String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Streak {
  id             Int      @id @default(sequence(maxValue: 2147483647))
  userId         Int      @unique
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActiveDate DateTime @default(now())
  totalPoints    Int      @default(0)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Challenge {
  id           Int                    @id @default(sequence(maxValue: 2147483647))
  title        String
  type         String
  startDate    DateTime               @default(now())
  endDate      DateTime
  status       String
  creatorId    Int
  description  String?
  goalValue    Float?
  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id            Int       @id @default(sequence(maxValue: 2147483647))
  challengeId   Int
  userId        Int
  role          String
  status        String
  rewardClaimed Boolean   @default(false)
  joinedAt      DateTime  @default(now())
  challenge     Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
}

model Badge {
  id          Int         @id @default(sequence(maxValue: 2147483647))
  name        String      @unique
  description String
  iconName    String
  userBadges  UserBadge[]
}

model UserBadge {
  id       Int      @id @default(sequence(maxValue: 2147483647))
  userId   Int
  badgeId  Int
  earnedAt DateTime @default(now())
  badge    Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
}

model ChatSession {
  id        String        @id @default(uuid())
  userId    Int
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        Int         @id @default(sequence(maxValue: 2147483647))
  sessionId String
  role      String
  content   String      @db.String(2000)
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model DailyProgress {
  id                    Int      @id @default(sequence(maxValue: 2147483647))
  userId                Int
  date                  DateTime @default(now()) @db.Date
  totalCaloriesConsumed Float    @default(0.0)
  calorieGoal           Float    @default(0.0)
  goalAchieved          Boolean  @default(false)
  currentWeight         Float?
  mood                  String?
  movement              Int      @default(0)
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model UploadedFile {
  id        String   @id @default(uuid())
  data      Bytes
  mimetype  String
  createdAt DateTime @default(now())
}
