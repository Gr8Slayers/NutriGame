// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Veritabanı olarak PostgreSQL kullanıyoruz
  url      = env("DATABASE_URL") // Bu, .env dosyasından gelecek
}

// === KULLANICI MODELİ ===
model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  profile   UserProfile?  // sadece Prisma için, DB kolonu değil
}

model UserProfile {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  age            Int
  gender         String
  weight         Int
  height         Int
  target_weight  Int
  reason_to_diet String
  avatar_url     String

  // her UserProfile in bir User a bagli olmasini sagliyor, user da bir row silindiginde burada ilgili user in profili siliniyor
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

