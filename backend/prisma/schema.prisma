// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Veritabanı olarak PostgreSQL kullanıyoruz
  url      = env("DATABASE_URL") // Bu, .env dosyasından gelecek
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  email     String    @unique
  password  String
  createdAt DateTime  @default(now())
  profile   UserProfile?  // sadece Prisma için, DB kolonu değil
}

model UserProfile {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  age            Int
  gender         String
  weight         Int
  height         Int
  target_weight  Int
  reason_to_diet String
  avatar_url     String

  // her UserProfile in bir User a bagli olmasini sagliyor, user da bir row silindiginde burada ilgili user in profili siliniyor
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FoodLookup{
  id              Int      @id @default(autoincrement())
  food_id         Int      @unique
  food_name       String
  p_unit          String //porsiyon miktarinin hangi birim oldugu orn. gram, ml, tabak, kasik
  p_amount        Float //porsiyon miktari orn. 100(gram), 200(ml), 2(tabak), 3(kasik)
  p_calorie       Float
  p_protein       Float //birimi zaten hep gram bu yuzden ozellestirmiyorum direkt miktar tutuluyor
  p_fat           Float //birimi zaten hep gram bu yuzden ozellestirmiyorum direkt miktar tutuluyor
  p_carb          Float //birimi zaten hep gram bu yuzden ozellestirmiyorum direkt miktar tutuluyor
}

model MealLog {
  meal_log_id     Int      @id @default(autoincrement())
  userId          Int      
  date            DateTime @db.Date @default(now()) // prisma sadece Date kabul etmiyor Datetime var sadece, yanina ekledigim aciklama db de Date olarak tutlmayi sagliyor
  meal_category   String //ogun tipi orn. sabah, ogle, aksam, araogun bunlardan baska olmayacak enum lanabilir
  p_count         Int //kac porsiyon eklendigi, toplamlar buna gore hesaplanacak
  food_id         Int
  food_name       String
  p_unit          String //porsiyon miktarinin hangi birim oldugu orn. gram, ml, tabak, kasik
  t_amount        Float // portion_count ile portion amount carpimi, yani o log icin total amount
  t_calorie       Float
  t_protein       Float
  t_fat           Float
  t_carb          Float
}

model MealTotals{
  id              Int      @id @default(autoincrement())
  userId          Int
  date            DateTime @db.Date @default(now()) // prisma sadece Date kabul etmiyor Datetime var sadece, yanina ekledigim aciklama db de Date olarak tutlmayi sagliyor
  meal_category   String //ogun tipi orn. sabah, ogle, aksam, araogun, OVERALL(yani tum gun) bunlardan baska olmayacak enum lanabilir     
  t_calorie       Float
  t_protein       Float
  t_fat           Float
  t_carb          Float

  @@unique([userId, date, meal_category]) //1 user 1 gunde 1 ogun icin birden fazla row olusturamaz
}

model WaterLog {
  water_log_id    Int      @id @default(autoincrement())
  userId          Int      
  date            DateTime @db.Date @default(now()) // prisma sadece Date kabul etmiyor Datetime var sadece, yanina ekledigim aciklama db de Date olarak tutlmayi sagliyor
  t_amount        Int

  @@unique([userId, date]) //1 user 1 gun icin birden fazla row olusturamaz
}


