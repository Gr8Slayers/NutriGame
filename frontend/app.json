{
  "expo": {
    "name": "NUTRIGAME",
    "slug": "NUTRIGAME",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "extra": {
      "apiUrl": "https://nutrigame-754w.onrender.com",
      "eas": {
        "projectId": "6a01f1fa-c06f-4db3-93f0-738220760b60"
      }
    },
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBE577"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.betulaydeger.nutrigame",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FBE577"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logo.png",
      "bundler": "metro",
      "output": "single",
      "name": "NutriGame",
      "shortName": "NutriGame",
      "description": "Gamified Nutrition and Health Tracking",
      "backgroundColor": "#FBE577",
      "themeColor": "#FBE577",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-secure-store",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#FBE577"
        }
      ]
    ]
  }
}